# Host-run defaults for local development.
# Docker Compose services override container-to-container URLs with service DNS names.
ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://ares:ares@localhost:55432/ares
ARES_API_KEYS=dev-key-1,dev-key-2
ARES_API_URL=http://localhost:8000/api/v1
ARES_DASHBOARD_URL=http://localhost:8501
CELERY_ENABLED=false
REDIS_URL=redis://localhost:6379/0
MLFLOW_TRACKING_URI=http://localhost:5000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:9000
DVC_REMOTE_URL=s3://ares-data
GOLDEN_SET_VERSION=v1.0.0
GOLDEN_SET_REQUIRE_CHECKSUM=true
GOLDEN_SET_SKIP_CHECKSUM=false
GITHUB_TOKEN=
SLACK_WEBHOOK_URL=
OTEL_EXPORTER_OTLP_ENDPOINT=