{
  "title": "ARES Production Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["ares", "mlops", "model-governance"],
  "panels": [
    {"type": "stat", "title": "Active Requests", "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4}, "targets": [{"expr": "ares_active_requests"}]},
    {"type": "timeseries", "title": "API Request Latency", "gridPos": {"x": 6, "y": 0, "w": 9, "h": 8}, "targets": [{"expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))"}]},
    {"type": "timeseries", "title": "Gate Decisions", "gridPos": {"x": 15, "y": 0, "w": 9, "h": 8}, "targets": [{"expr": "sum(rate(ares_gate_decisions_total[5m])) by (decision)"}]},
    {"type": "timeseries", "title": "Evaluation Runs", "gridPos": {"x": 0, "y": 8, "w": 8, "h": 8}, "targets": [{"expr": "sum(rate(ares_evaluation_runs_total[5m])) by (status)"}]},
    {"type": "timeseries", "title": "Drift Alerts", "gridPos": {"x": 8, "y": 8, "w": 8, "h": 8}, "targets": [{"expr": "increase(ares_drift_alerts_total[1h])"}]},
    {"type": "timeseries", "title": "Auth Failures", "gridPos": {"x": 16, "y": 8, "w": 8, "h": 8}, "targets": [{"expr": "sum(rate(ares_auth_failures_total[5m]))"}]}
  ]
}
