services:
  postgres:
    image: postgres:16
    environment:
      POSTGRES_USER: ares
      POSTGRES_PASSWORD: ares
      POSTGRES_DB: ares_test
    ports: ["5432:5432"]
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ares"]
      interval: 5s
      timeout: 5s
      retries: 3
  redis:
    image: redis:7-alpine
  api:
    build:
      context: .
      dockerfile: docker/Dockerfile.api
    env_file: .env.example
    mem_limit: 512m